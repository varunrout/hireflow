# HireFlow API - Environment Variables
# Copy this file to .env and fill in the values

# Application
APP_NAME=HireFlow API
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# Server
HOST=0.0.0.0
PORT=8000

# Security - CHANGE THIS IN PRODUCTION
SECRET_KEY=dev-secret-key-change-in-production-at-least-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# Database
DATABASE_URL=postgresql://hireflow:hireflow@localhost:5432/hireflow

# Redis
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# S3 / MinIO Object Storage
S3_ENDPOINT_URL=http://localhost:9000
S3_BUCKET_NAME=hireflow-uploads
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_REGION=us-east-1

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key

# CORS (comma-separated list)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Sentry (optional)
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project
